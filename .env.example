# Copy this to .env and fill in values for cloud deployment
# For local development, these are all optional

# Set to 1 for cloud hosting (Render, Railway, etc.)
CLOUD_MODE=1

# Flask secret key (auto-generated if not set)
SECRET_KEY=your-random-secret-key-here

# Port (auto-set by most cloud hosts)
PORT=5000

# Database path (use persistent disk mount on cloud)
# DATABASE_PATH=/data/bidding_tracker.db

# Debug mode (never enable in production)
DEBUG=0
